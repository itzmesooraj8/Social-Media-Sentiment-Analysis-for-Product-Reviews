# ─────────────────────────────────────────────────────
# Sentinel Frontend – Environment Variables
# Copy these into Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────

# Your Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Your Supabase anon/public key (Project Settings → API → anon public)
VITE_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your deployed Render backend URL (NO trailing slash, NO /api suffix)
VITE_API_URL=https://social-media-sentiment-analysis-for.onrender.com
